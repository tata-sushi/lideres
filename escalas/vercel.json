{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "ignoreCommand": "git diff --quiet HEAD^ HEAD -- escalas/",
  "rewrites": [
    { "source": "/api/proxy", "destination": "/api/proxy" },
    { "source": "/escalas/(.*)", "destination": "/index.html" },
    { "source": "/escalas", "destination": "/index.html" }
  ]
}
